#include <winver.h>

#define VER_FILE   @ARCDPS_LL_VERSION_MAJOR@,@ARCDPS_LL_VERSION_MINOR@,@ARCDPS_LL_VERSION_PATCH@,@ARCDPS_LL_VERSION_TWEAK@
#define VER_STR    "@ARCDPS_LL_VERSION_STRING@\0"

VS_VERSION_INFO VERSIONINFO
    FILEVERSION    VER_FILE
    PRODUCTVERSION VER_FILE
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0x0L
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_DLL
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "arcdps_legacy_loader\0"
            VALUE "FileDescription",  "arcdps legacy addon loader\0"
            VALUE "FileVersion",      VER_STR
            VALUE "InternalName",     "arcdps_legacy_loader\0"
            VALUE "OriginalFilename", "arcdps_legacy_loader.dll\0"
            VALUE "ProductName",      "arcdps_legacy_loader\0"
            VALUE "ProductVersion",   VER_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 0x4B0
    END
END
